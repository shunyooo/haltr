{
  "name": "haltr",
  "version": "0.0.1",
  "description": "Quality assurance tool for coding agent outputs",
  "type": "module",
  "main": "./dist/bin/hal.js",
  "bin": {
    "hal": "./dist/bin/hal.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/agents dist/",
    "test": "node --import tsx src/test/m1-validation.ts && node --import tsx src/test/m2-validation.ts && node --import tsx src/test/m3-validation.ts && node --import tsx src/test/m4-validation.ts && node --import tsx src/test/m6-validation.ts && node --import tsx src/test/m7-validation.ts",
    "test:schema": "node --import tsx src/test/m1-validation.ts",
    "test:crud": "node --import tsx src/test/m2-validation.ts",
    "test:history": "node --import tsx src/test/m3-validation.ts",
    "test:gates": "node --import tsx src/test/m4-validation.ts",
    "test:cli": "node --import tsx src/test/m6-validation.ts",
    "test:commands": "node --import tsx src/test/m7-validation.ts",
    "test:tmux": "node --import tsx src/test/tmux-e2e.ts",
    "test:e2e": "node --import tsx src/test/agent-e2e.ts",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/"
  },
  "keywords": [],
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsx": "^4.19.0"
  }
}

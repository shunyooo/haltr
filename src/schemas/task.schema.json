{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "haltr task v2",
  "type": "object",
  "required": [
    "id",
    "goal"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/taskStatus"
    },
    "accept": {
      "$ref": "#/$defs/accept"
    },
    "plan": {
      "type": "string"
    },
    "context": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      }
    },
    "history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/historyEvent"
      }
    }
  },
  "$defs": {
    "taskStatus": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "done",
        "failed"
      ]
    },
    "stepStatus": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "done",
        "failed"
      ]
    },
    "accept": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      ]
    },
    "step": {
      "type": "object",
      "required": [
        "id",
        "goal"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "goal": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/stepStatus"
        },
        "accept": {
          "$ref": "#/$defs/accept"
        },
        "verified": {
          "type": "boolean"
        }
      }
    },
    "historyEvent": {
      "type": "object",
      "required": [
        "at",
        "type"
      ],
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["at", "type"],
          "properties": {
            "at": { "type": "string" },
            "type": { "const": "created" },
            "message": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["at", "type"],
          "properties": {
            "at": { "type": "string" },
            "type": { "const": "updated" },
            "message": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["at", "type", "step"],
          "properties": {
            "at": { "type": "string" },
            "type": { "const": "step_added" },
            "step": { "type": "string" },
            "message": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["at", "type", "step"],
          "properties": {
            "at": { "type": "string" },
            "type": { "const": "step_started" },
            "step": { "type": "string" },
            "message": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["at", "type", "step"],
          "properties": {
            "at": { "type": "string" },
            "type": { "const": "step_done" },
            "step": { "type": "string" },
            "message": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["at", "type", "step"],
          "properties": {
            "at": { "type": "string" },
            "type": { "const": "step_failed" },
            "step": { "type": "string" },
            "message": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["at", "type", "step"],
          "properties": {
            "at": { "type": "string" },
            "type": { "const": "step_verified" },
            "step": { "type": "string" },
            "result": { "type": "string", "enum": ["PASS", "FAIL"] },
            "message": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["at", "type"],
          "properties": {
            "at": { "type": "string" },
            "type": { "const": "paused" },
            "message": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["at", "type"],
          "properties": {
            "at": { "type": "string" },
            "type": { "const": "resumed" },
            "message": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["at", "type"],
          "properties": {
            "at": { "type": "string" },
            "type": { "const": "completed" },
            "message": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["at", "type"],
          "properties": {
            "at": { "type": "string" },
            "type": { "const": "user_feedback" },
            "message": { "type": "string" }
          }
        }
      ]
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "haltr config v2",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "timezone": {
      "type": "string",
      "description": "IANA timezone for displaying times (e.g. Asia/Tokyo). Falls back to TZ env var, then UTC."
    },
    "haltr_dir": {
      "type": "string",
      "description": "Path to haltr directory (default: \"haltr\")"
    }
  }
}

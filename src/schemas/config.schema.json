{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "haltr config (.haltr.json)",
  "type": "object",
  "additionalProperties": false,
  "required": ["directory"],
  "properties": {
    "directory": {
      "type": "string",
      "description": "Name of the haltr directory (e.g. \"work\")"
    },
    "timezone": {
      "type": "string",
      "description": "IANA timezone for displaying times (e.g. Asia/Tokyo). Falls back to TZ env var, then UTC."
    }
  }
}
